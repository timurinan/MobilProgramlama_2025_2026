<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity" >

    <EditText
        android:id="@+id/txt_adsoyad"
        android:layout_margin="100dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="text"
        android:gravity="center"
        android:hint="Adı Soyadı"  />

    <EditText
        android:id="@+id/txt_kartno"
        android:hint="Kart Numarası"
        android:layout_below="@id/txt_adsoyad"
        android:layout_alignLeft="@id/txt_adsoyad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="number" />

    <EditText
        android:id="@+id/txt_cvv"
        android:layout_below="@id/txt_kartno"
        android:layout_alignRight="@id/txt_kartno"
        android:layout_marginTop="50dp"
        android:hint="CVV"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="date" />

    <EditText
        android:id="@+id/txt_skt"
        android:layout_width="90dp"
        android:layout_below="@id/txt_kartno"
        android:layout_marginTop="50dp"
        android:layout_alignLeft="@id/txt_kartno"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="SKT"
        android:inputType="date" />

    <Button
        android:id="@+id/btn_onayla"
        android:layout_below="@id/txt_skt"
        android:layout_marginTop="50dp"
        android:layout_centerInParent="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Onayla" />
</RelativeLayout>
