<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <EditText
        android:id="@+id/txt_proje_not"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="300dp"
        android:ems="10"
        android:hint="Proje Notu"
        android:inputType="number"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/txt_proje_ağırlık"
        android:layout_width="134dp"
        android:layout_height="47dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="296dp"
        android:ems="10"
        android:hint="Proje Ağırlık"
        android:inputType="number"
        app:layout_constraintStart_toEndOf="@+id/txt_vize_not"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/txt_final_not"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="204dp"
        android:ems="10"
        android:hint="Final Notu"
        android:inputType="number"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/txt_final_ağırlık"
        android:layout_width="134dp"
        android:layout_height="47dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="200dp"
        android:ems="10"
        android:hint="Final Ağırlık"
        android:inputType="number"
        app:layout_constraintStart_toEndOf="@+id/txt_vize_not"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/txt_vize_not"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="100dp"
        android:ems="10"
        android:hint="Vize Notu"
        android:inputType="number"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/txt_vize_ağırlık"
        android:layout_width="134dp"
        android:layout_height="47dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="96dp"
        android:ems="10"
        android:hint="Vize Ağırlık"
        android:inputType="number"
        app:layout_constraintStart_toEndOf="@+id/txt_vize_not"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="76dp"
        android:layout_marginEnd="132dp"
        android:text="Hesapla"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_proje_not" />

    <TextView
        android:id="@+id/txt_ortalama"
        android:layout_width="348dp"
        android:layout_height="49dp"
        android:layout_marginStart="44dp"
        android:layout_marginTop="64dp"
        android:text="Ortalama BuradaGörüntülenecek"
        android:gravity="center"
        android:textSize="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button" />
</androidx.constraintlayout.widget.ConstraintLayout>